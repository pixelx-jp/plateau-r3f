{
  "name": "@yodolabs/plateau-r3f",
  "version": "0.1.1",
  "description": "React Three Fiber library for PLATEAU 3D Tiles with attribute coloring and hazard layers",
  "license": "MIT",
  "author": "Yodo Labs <pan@yodolabs.jp> (https://yodolabs.jp)",
  "homepage": "https://pixelx-jp.github.io/plateau-r3f/",
  "repository": {
    "type": "git",
    "url": "https://github.com/pixelx-jp/plateau-r3f.git"
  },
  "bugs": {
    "url": "https://github.com/pixelx-jp/plateau-r3f/issues",
    "email": "pan@yodolabs.jp"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.ja.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench --run test/bench",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "peerDependencies": {
    "@react-three/fiber": ">=8",
    "react": ">=18",
    "react-dom": ">=18",
    "three": ">=0.160"
  },
  "dependencies": {
    "@mapbox/vector-tile": "^2.0.5",
    "3d-tiles-renderer": "^0.4.0",
    "apache-arrow": "^17.0.0",
    "earcut": "^3.0.2",
    "pbf": "^4.0.2",
    "pmtiles": "^4.3.2",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@react-three/fiber": "^8.17.0",
    "@types/earcut": "^3.0.0",
    "@types/mapbox__vector-tile": "^1.3.4",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "playwright": "^1.60.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sharp": "^0.34.5",
    "three": "^0.169.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "plateau",
    "3d-tiles",
    "react-three-fiber",
    "three",
    "citygml",
    "japan",
    "gis"
  ]
}
